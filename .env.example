# ===========================================================================
# Azure AI Search Application - Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Authentication uses Managed Identity (DefaultAzureCredential).
# No API keys are needed. Assign the "Search Index Data Reader" role to
# your App Service's system-assigned managed identity on the search service.
# ===========================================================================

# Azure AI Search Configuration
# ---------------------------------------------------------------------------
# Your Azure AI Search endpoint URL (found in Overview section)
AZURE_SEARCH_ENDPOINT=https://YOUR-SEARCH-SERVICE.search.windows.net

# Your Azure AI Search Index Name (found in Indexes section)
AZURE_SEARCH_INDEX_NAME=YOUR-INDEX-NAME

# Semantic Search Configuration (Optional)
# If your index has a semantic configuration, set its name here.
# Enables AI-powered semantic ranking and query rewriting.
# Leave empty or comment out to use standard keyword search.
AZURE_SEARCH_SEMANTIC_CONFIG=YOUR-SEMANTIC-CONFIG-NAME

# Server Configuration
PORT=3000
